# ============================================================================
# laravel-rebel-ai-guard — environment variables
# ============================================================================

# Open an OTP-bombing case when this many failed email-OTP verifications target one
# identifier within the scan window.
REBEL_AIGUARD_OTP_BOMBING_THRESHOLD=10

# Automatic detection. When true, the package schedules `rebel:detect-anomalies` hourly so
# cases appear on their own. Set to false to opt out. LOOKBACK is the default scan window
# (minutes, ending "now"); the command's --lookback option overrides it per run.
REBEL_AIGUARD_SCHEDULE=true
REBEL_AIGUARD_LOOKBACK=1440
